# Copy this file to .env.local and fill in real values from your Stripe dashboard.
# .env.local is gitignored — never commit real keys.
#
# Use TEST MODE values while developing (toggle "Test mode" in the Stripe
# dashboard first) — sk_test_... and price IDs created while in test mode.
# Only switch to live values once a full test purchase has worked end to end.

# Master switch for checkout. Unset/false = register-interest mode (payment
# buttons greyed out). In Vercel: set to "true" for Preview only while testing;
# set in Production on launch day. Must be NEXT_PUBLIC_ so the page can read it.
NEXT_PUBLIC_CHECKOUT_ENABLED=

# Stripe secret key (test mode: sk_test_..., live mode: sk_live_...)
STRIPE_SECRET_KEY=

# Price IDs for the two plans — must start with "price_", not "prod_".
# Find them on each Product's page in the Stripe dashboard, under "Pricing".
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_LIFETIME=

# Signing secret for the Stripe webhook endpoint (from `stripe listen` in dev,
# or the webhook's settings page in the dashboard for production).
STRIPE_WEBHOOK_SECRET=

# Used to build Stripe's success/cancel redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — used for the beta "register interest" list and for emailing you
# contact-form submissions. Get the API key from resend.com/api-keys.
# Every Resend account has one default Audience; contacts are added to it
# directly, no audience ID needed.
RESEND_API_KEY=

# Where "Talk to us" contact form submissions get emailed to.
CONTACT_NOTIFY_EMAIL=

# --- Licensing (see LICENSING-PLAN.md in the parent folder) ---

# Injected automatically when you connect Neon via Vercel -> Storage.
# For local dev, copy the connection string from the Neon dashboard.
DATABASE_URL=

# Ed25519 private key (base64 PKCS8) for signing licence tokens.
# Generate once; the matching public key is embedded in the Flame exe.
LICENSE_SIGNING_KEY=

# Verified sender for licence-key emails, e.g. "Plot-LV <keys@your-domain>".
# Until the domain is verified in Resend, leave unset (falls back to
# onboarding@resend.dev, which only delivers to your own address).
RESEND_FROM=
