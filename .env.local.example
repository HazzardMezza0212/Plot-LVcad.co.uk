# Copy this file to .env.local and fill in real values from your Stripe dashboard.
# .env.local is gitignored — never commit real keys.
#
# Use TEST MODE values while developing (toggle "Test mode" in the Stripe
# dashboard first) — sk_test_... and price IDs created while in test mode.
# Only switch to live values once a full test purchase has worked end to end.

# Stripe secret key (test mode: sk_test_..., live mode: sk_live_...)
STRIPE_SECRET_KEY=

# Price IDs for the two plans — must start with "price_", not "prod_".
# Find them on each Product's page in the Stripe dashboard, under "Pricing".
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_LIFETIME=

# Signing secret for the Stripe webhook endpoint (from `stripe listen` in dev,
# or the webhook's settings page in the dashboard for production).
STRIPE_WEBHOOK_SECRET=

# Used to build Stripe's success/cancel redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — used for the beta "register interest" list (and later, sending
# licence key / contact emails). Get the API key from resend.com/api-keys.
# Every Resend account has one default Audience; contacts are added to it
# directly, no audience ID needed.
RESEND_API_KEY=
